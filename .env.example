# Copy to .env and fill in real values. Never commit .env.

# ── Supabase ──────────────────────────────────────
# Find these at: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...      # The "anon public" key — safe to expose in browser
# DO NOT put the service_role key here. It belongs only in server-side scripts.

# ── Auth ──────────────────────────────────────────
# Usernames in the login form get this suffix appended before sign-in.
VITE_AUTH_EMAIL_DOMAIN=yourcompany.com

# ── AI (Gemini) ───────────────────────────────────
# The Gemini key is NO LONGER a client var — it must not ship in the browser
# bundle. It now lives ONLY as a Supabase Edge Function secret:
#   supabase secrets set GEMINI_API_KEY=<your key>
# and is consumed by supabase/functions/gemini. Rotate any key that was
# previously exposed through VITE_GEMINI_API_KEY.
